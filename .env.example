# 内部 API 认证令牌 (生产环境必填，前后端需一致)
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
API_AUTH_TOKEN=

# JWT 密钥 (必填, 生产环境用强随机值)
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
# 后端启动时会检查是否为默认值, 是则拒绝启动
JWT_SECRET=change-me-in-production

# CORS 允许的域名 (逗号分隔, 默认为本地开发)
# 生产环境务必改为实际前端域名, 如: https://app.example.com
CORS_ORIGINS=http://localhost:4524

# 环境标识 (development / production)
# development: 允许 react-dev-inspector, Cookie 不设置 Secure 标志
# production: 隐藏 dev 工具, Cookie 设置 Secure 标志
NODE_ENV=development

# Apimart 轮询保活配置（后端读取）
APIMART_INITIAL_WAIT_SECONDS=15
APIMART_POLL_INTERVAL_SECONDS=4
APIMART_POLL_TIMEOUT_SECONDS=3600
SSE_IDLE_TIMEOUT_SECONDS=300
