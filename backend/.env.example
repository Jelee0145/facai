# 内部 API 认证令牌 (生产环境必填，前后端需一致)
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
API_AUTH_TOKEN=

# Apimart API Key (必填)
APIMART_API_KEY=your_api_key_here

# JWT 签名密钥 (必填，启动时自动生成随机值)
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# CORS 允许的域名 (逗号分隔，生产改为实际前端域名)
CORS_ORIGINS=http://localhost:4524

# 环境标识 (development / production)
NODE_ENV=development

# 管理员密码 (不设则自动生成随机密码)
ADMIN_PASSWORD=
