# 内部 API 认证令牌 (生产环境必填，前后端需一致)
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
API_AUTH_TOKEN=

# Apimart API Key (必填)
APIMART_API_KEY=your_api_key_here

# JWT 签名密钥 (必填，启动时自动生成随机值)
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# CORS 允许的域名 (逗号分隔，生产改为实际前端域名)
CORS_ORIGINS=http://localhost:4524

# 环境标识 (development / production)
NODE_ENV=development

# Apimart 轮询保活配置
# 生成通常较慢；后端持续轮询直到图片完成、上游返回失败，或达到总超时。
APIMART_INITIAL_WAIT_SECONDS=15
APIMART_POLL_INTERVAL_SECONDS=4
APIMART_POLL_TIMEOUT_SECONDS=3600
SSE_IDLE_TIMEOUT_SECONDS=300

# 管理员密码 (不设则自动生成随机密码)
ADMIN_PASSWORD=

# ===== 测试账号控制 (仅开发/测试环境生效) =====
# 启用测试管理员账号 (true/false) — 生产环境强制禁用
ENABLE_TEST_ADMIN=
# 测试管理员口令 (默认 admin123)
TEST_ADMIN_PASSWORD=
# 启用前台无限积分测试用户 (true/false) — 生产环境强制禁用
ENABLE_TEST_UNLIMITED_USER=
# 前台测试用户口令
TEST_USER_PASSWORD=
